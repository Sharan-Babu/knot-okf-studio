{
  "name": "knot-okf-studio",
  "version": "1.1.0",
  "description": "A local-first desktop studio for Open Knowledge Format bundles.",
  "desktopName": "Knot",
  "main": "./out/main/index.js",
  "author": "Knot Studio",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build && npm run build:services",
    "build:services": "node scripts/build-services.mjs",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:live-ai": "npm run build && KNOT_LIVE_AI=1 playwright test tests/e2e/live-ai.spec.ts --workers=1",
    "test:mcp": "npm run build:services && node tests/mcp-probe.mjs && node tests/cloud-host-probe.mjs",
    "test:ship": "npm run typecheck && npm test && npm run test:mcp && npm run test:e2e",
    "test:packaged:mac": "node tests/packaged-smoke.mjs",
    "test:packaged:linux": "node tests/packaged-linux-smoke.mjs",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@daytona/sdk": "0.199.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.3",
    "@radix-ui/react-tabs": "1.1.17",
    "@radix-ui/react-tooltip": "1.2.12",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "d3-force": "^3.0.0",
    "express": "5.1.0",
    "fflate": "0.8.3",
    "gray-matter": "4.0.3",
    "html-to-text": "9.0.5",
    "lucide-react": "1.24.0",
    "mammoth": "1.12.0",
    "markdown-it": "14.3.0",
    "pdf-parse": "1.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "yaml": "2.9.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/tsconfig": "2.0.0",
    "@electron-toolkit/utils": "4.0.0",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/express": "5.0.3",
    "@types/html-to-text": "9.0.4",
    "@types/markdown-it": "14.1.2",
    "@types/node": "26.1.1",
    "@types/pdf-parse": "1.1.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "39.8.10",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "esbuild": "0.25.12",
    "jsdom": "29.1.1",
    "png-to-ico": "3.0.2",
    "typescript": "7.0.2",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "build": {
    "appId": "studio.knot.okf",
    "productName": "Knot",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "out/services",
        "to": "services"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis",
        "portable",
        "zip"
      ]
    },
    "linux": {
      "category": "Office",
      "icon": "resources/icon.png",
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
